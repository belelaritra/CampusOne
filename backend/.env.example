# Copy this file to .env and fill in your values
# cp .env.example .env
# run.sh / runwin.sh fill this automatically — only edit manually for Option B setup.

# Django secret key — signs sessions, CSRF tokens, password resets.
# Generate with:
#   python3 -c "import secrets, string; chars = string.ascii_letters + string.digits + '!@#\$%^&*(-_=+)'; print(''.join(secrets.choice(chars) for _ in range(50)))"
DJANGO_SECRET_KEY=your-50-char-random-string-here

# Shared secret between Django and the Telegram bot
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_BOT_SECRET=your-secret-here

# PostgreSQL app database (matches docker-compose.yml app-db service)
DB_NAME=campusone
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5433
