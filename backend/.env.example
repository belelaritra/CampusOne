# Copy this file to .env and fill in your values
# cp .env.example .env

# Shared secret between Django and the Telegram bot
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_BOT_SECRET=your-secret-here

# PostgreSQL app database (matches docker-compose.yml app-db service)
DB_NAME=campusone
DB_USER=admin
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5433
